*.aux
*.log
*.out
*.bbl
*.blg
*.fdb_latexmk
*.fls
*.synctex.gz
*.toc

# ═══ IDE / EDITOR ═══
.idea/
.vscode/
*.swp
*.swo
*~

# ═══ OS ═══
.DS_Store
Thumbs.db
NUL
desktop.ini

